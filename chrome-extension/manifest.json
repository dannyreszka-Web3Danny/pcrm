{
  "manifest_version": 3,
  "name": "PCRM LinkedIn Clipper",
  "version": "1.0.0",
  "description": "Clip LinkedIn profile data into PCRM with one click.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PCRM LinkedIn Clipper"
  }
}
