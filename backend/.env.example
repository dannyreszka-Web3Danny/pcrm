# PCRM Backend Environment Variables
# Copy this file to .env and fill in real values

# API authentication (required — must match frontend PCRM_API_SECRET setting)
PCRM_API_SECRET=your-strong-api-secret-here

# n8n Intelligence Campaign Workflow webhook URL
# Get from n8n > your campaign workflow > Webhook node > URL
N8N_CAMPAIGN_WEBHOOK_URL=http://178.104.168.218:5678/webhook/campaign-research

# Supabase — STEP 28D (required for Supabase data sync)
# Project URL from supabase.com > your project > Settings > API
SUPABASE_URL=https://xxx.supabase.co
# Service role key from supabase.com > your project > Settings > API
# SECURITY — service role key grants full DB access. Never expose this in frontend code.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
